        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.7.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.9.5",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.65.0",
        "vitest": "^4.1.10"
    }
